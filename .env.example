# Copy to .env and fill in, or export directly in your shell.
# NEVER commit real keys.

# Required only for LLM features (`skill`, and the skill step of `pack`).
# Get one at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Optional overrides
# AGENTIC_MODEL=google/gemini-3.5-flash
# AGENTIC_BASE_URL=https://openrouter.ai/api/v1
